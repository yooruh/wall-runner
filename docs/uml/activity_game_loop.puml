@startuml

title WallRunner v3.0 — 游戏主循环活动图

start

:获取 activePlayers;
if (activePlayers为空?) then (是)
  :checkAllDead();
  stop
else (否)
endif

:updateObstacles();

fork
  :processKnockback(每个玩家);
  :processInvincibility(每个玩家);
fork again
  :updatePlayerMovement(每个玩家);
  :检测玩家间碰撞;
  if (发生碰撞?) then (是)
    :resolvePlayerCollision();
    if (一方跳跃?) then (是)
      :applyKnockback();
    else (否)
      :overlap分离;
    endif
  else (否)
  endif
end fork

:updatePlayerCameras();
:updateDisplayCamera();
:checkDeathLine();
:checkAllDead();
:applyTimeBonus();
:recalculateScores();
:checkSpawn();
:updateDifficulty();
:updateCollectibles();

:frames++;

stop
@enduml
