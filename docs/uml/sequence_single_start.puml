@startuml
autonumber

title WallRunner v3.0 — 单人游戏启动时序图

actor 玩家 as Player
participant "MenuController" as MC
participant "GameController" as GC
participant "StateManager" as SM
participant "LocalPhysicsEngine" as LPE
participant "GameLoopService" as Loop
participant "Renderer" as REN
participant "InputService" as INP

Player -> MC : 点击"单人游戏"
MC -> GC : switchScene(game.fxml)
GC -> GC : initialize()
GC -> SM : initLocalState(name)
SM -> SM : create GameState
SM --> GC : state ready
GC -> LPE : initState(state)
LPE --> GC : state initialized
GC -> REN : bindCanvas(canvas)
GC -> INP : attach(scene)
GC -> Loop : setOnTick(callback)
GC -> Loop : start()
Loop --> GC : tick loop running
GC --> MC : scene ready
MC --> Player : 显示游戏画面

note right of GC
  所有服务通过接口注入
  默认构造器自动组装
end note
@enduml
