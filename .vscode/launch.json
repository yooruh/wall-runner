{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Client",
            "request": "launch",
            "mainClass": "com.wallrunner.client.ClientApplication",
            "cwd": "${workspaceFolder}/client",
            // 如果本地 JavaFX SDK 路径不同，请修改下方 vmArgs
            "vmArgs": "--module-path D:\\ProgramCode\\.jdks\\javafx-sdk-21.0.11\\lib --add-modules javafx.controls,javafx.fxml"
        },
        {
            "type": "java",
            "name": "Server",
            "request": "launch",
            "mainClass": "com.wallrunner.server.WallRunnerServer",
            "cwd": "${workspaceFolder}/server"
        }
    ]
}
