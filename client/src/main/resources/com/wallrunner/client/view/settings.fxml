<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wallrunner.client.controller.SettingsController"
      alignment="CENTER"
      spacing="0"
      styleClass="settings-box"
      prefWidth="380" prefHeight="680">

    <padding>
        <Insets top="20" right="0" bottom="20" left="0"/>
    </padding>

    <Label text="游戏设置" styleClass="settings-title">
        <VBox.margin><Insets bottom="12"/></VBox.margin>
    </Label>

    <!-- 滚动区域 -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="settings-scroll-pane" VBox.vgrow="ALWAYS">
        <VBox spacing="16" alignment="CENTER">
            <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>

            <!-- ===== 玩家信息 ===== -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="320">
                <Label text="▎玩家信息" styleClass="settings-section-title"/>
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="玩家名称" styleClass="settings-label"/>
                    <TextField fx:id="nameField" promptText="输入你的名字" styleClass="name-input"/>
                </VBox>
            </VBox>

            <!-- ===== 网络设置 ===== -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="320">
                <Label text="▎网络设置" styleClass="settings-section-title"/>
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="服务器地址" styleClass="settings-label"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="serverAddressField" promptText="localhost" styleClass="settings-input" HBox.hgrow="ALWAYS"/>
                        <Label text=":" styleClass="settings-unit"/>
                        <TextField fx:id="serverPortField" promptText="8080" styleClass="settings-input, number" prefWidth="60"/>
                    </HBox>
                    <Label text="跨设备联机时填写服务器 IP（如 192.168.137.1）" styleClass="settings-hint"/>
                </VBox>
            </VBox>

            <!-- ===== 游戏玩法 ===== -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="320">
                <Label text="▎游戏玩法" styleClass="settings-section-title"/>
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="时间奖励间隔 (秒)" styleClass="settings-label"/>
                    <TextField fx:id="timeIntervalField" promptText="5.0" styleClass="settings-input, number"/>
                    <Label text="时间奖励分数" styleClass="settings-label"/>
                    <TextField fx:id="timePointsField" promptText="10" styleClass="settings-input, number"/>
                </VBox>
            </VBox>

            <!-- ===== 按键绑定 ===== -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="320">
                <Label text="▎按键绑定" styleClass="settings-section-title"/>
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="跳跃键绑定" styleClass="settings-label"/>
                    <VBox fx:id="jumpKeysContainer" spacing="4"/>
                    <Button fx:id="btnAddJumpKey" text="+ 添加按键" styleClass="settings-add-button"/>
                    <Label fx:id="jumpKeyHint" text="点击上方按钮后，按下想绑定的按键" styleClass="settings-hint"/>
                </VBox>
            </VBox>

            <!-- ===== 显示设置 ===== -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="320">
                <Label text="▎显示设置" styleClass="settings-section-title"/>
                <VBox spacing="8" alignment="CENTER_LEFT">
                    <CheckBox fx:id="showFpsCheck" text="显示 FPS" styleClass="settings-check"/>
                    <CheckBox fx:id="soundCheck" text="音效" styleClass="settings-check"/>
                    <CheckBox fx:id="predictCheck" text="预测补偿" styleClass="settings-check"/>
                </VBox>
            </VBox>

            <!-- ===== 角色颜色 ===== -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="320">
                <Label text="▎角色颜色" styleClass="settings-section-title"/>
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <CheckBox fx:id="autoColorCheck" text="使用默认配色（自动分配不重复颜色）" styleClass="settings-check"/>
                    <VBox fx:id="customColorBox" spacing="6" alignment="CENTER_LEFT">
                        <Label text="自定义填充色 (HEX)" styleClass="settings-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="fillColorField" promptText="#4ecca3" styleClass="settings-input" HBox.hgrow="ALWAYS"/>
                            <Region fx:id="fillColorPreview" prefWidth="24" prefHeight="24" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #444;"/>
                        </HBox>
                        <Label text="自定义描边色 (HEX)" styleClass="settings-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="strokeColorField" promptText="#3db892" styleClass="settings-input" HBox.hgrow="ALWAYS"/>
                            <Region fx:id="strokeColorPreview" prefWidth="24" prefHeight="24" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #444;"/>
                        </HBox>
                        <Label text="留空则使用默认配色" styleClass="settings-hint"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- ===== 外观主题 ===== -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="320">
                <Label text="▎外观主题" styleClass="settings-section-title"/>
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="主题" styleClass="settings-label"/>
                    <ComboBox fx:id="themeSelector" promptText="深色" styleClass="settings-combo" maxWidth="320"/>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- 底部按钮 -->
    <HBox spacing="16" alignment="CENTER" maxWidth="320">
        <VBox.margin><Insets top="16"/></VBox.margin>
        <Button text="保存" onAction="#onSave" styleClass="menu-btn, resume" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="取消" onAction="#onCancel" styleClass="menu-btn, ghost" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

</VBox>