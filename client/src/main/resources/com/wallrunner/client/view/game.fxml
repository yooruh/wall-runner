<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wallrunner.client.controller.GameController"
            styleClass="game-root"
            prefWidth="640" prefHeight="780">

    <!-- 顶部工具条：采用v2布局样式 -->
    <top>
        <HBox fx:id="statusBar" spacing="12" alignment="CENTER_LEFT" styleClass="status-bar">
            <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
            <Label fx:id="connStatus" text="本地游戏" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="roomIdDisplay" text="" styleClass="room-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnPause" text="暂停" onAction="#onTogglePause" styleClass="toolbar-button"/>
            <Button fx:id="btnSettings" text="设置" onAction="#onOpenSettings" styleClass="toolbar-button"/>
            <Button fx:id="btnHome" text="返回" onAction="#onReturnToMenu" styleClass="toolbar-button"/>
        </HBox>
    </top>

    <!-- 中央游戏画布：对齐旧版本样式 -->
    <center>
        <StackPane alignment="CENTER" styleClass="game-canvas-container">
            <Canvas fx:id="gameCanvas" width="400" height="600"/>

            <!-- 暂停覆盖层：参考v2样式，加入"游戏设置" -->
            <VBox fx:id="pauseOverlay" visible="false" managed="false" alignment="CENTER" spacing="16"
                  styleClass="overlay-pane">
                <Label fx:id="pauseTitle" text="游戏暂停" styleClass="overlay-title"/>
                <Label fx:id="pauseHint" text="按 ESC 恢复游戏" styleClass="hint-label"/>
                <Button fx:id="btnResumeGame" text="继续游戏" onAction="#onTogglePause" styleClass="overlay-button"/>
                <Button fx:id="btnRespawn" text="立即重生" onAction="#onRestart" styleClass="overlay-button" visible="false" managed="false"/>
                <Button text="游戏设置" onAction="#onOpenSettings" styleClass="overlay-button-secondary"/>
                <Button text="返回菜单" onAction="#onReturnToMenu" styleClass="overlay-button-secondary"/>
            </VBox>

            <!-- 游戏结束覆盖层：参考v2样式 -->
            <VBox fx:id="gameOverOverlay" visible="false" managed="false" alignment="CENTER" spacing="16"
                  styleClass="overlay-pane">
                <Label text="游戏结束" styleClass="overlay-title"/>
                <Label fx:id="finalScoreLabel" text="" styleClass="overlay-score"/>
                <Button text="重新开始" onAction="#onRestart" styleClass="overlay-button"/>
                <Button text="返回菜单" onAction="#onReturnToMenu" styleClass="overlay-button-secondary"/>
            </VBox>

            <!-- 设置覆盖层 -->
            <VBox fx:id="settingsOverlay" visible="false" managed="false" alignment="CENTER"
                  styleClass="overlay-pane"
                  maxWidth="380" maxHeight="680"/>

            <!-- 底部提示已移到窗口底部（BorderPane.bottom） -->
        </StackPane>
    </center>

    <!-- 右侧排行榜：对齐旧版本 -->
    <right>
        <VBox fx:id="leaderboard" visible="false" managed="false" spacing="8" styleClass="leaderboard">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="排行榜" styleClass="lb-title"/>
            <VBox fx:id="lbList" spacing="4"/>
        </VBox>
    </right>

    <!-- 底部提示区域（窗口底部，游戏区域外） -->
    <bottom>
        <VBox alignment="CENTER" spacing="4" style="-fx-padding: 6; -fx-background-color: rgba(15,52,96,0.6);">
            <!-- 游戏提示小字 -->
            <HBox alignment="CENTER" spacing="8">
                <Label fx:id="hint" text="按跳跃键 / 点击屏幕 / 触摸 来跳跃" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
            </HBox>
            <!-- 死亡提示（默认隐藏） -->
            <HBox fx:id="bottomHintBox" visible="false" managed="false" alignment="CENTER" spacing="12">
                <Label fx:id="bottomDeathHint" text="" style="-fx-text-fill: #aaa; -fx-font-size: 12px;"/>
                <Button fx:id="bottomRespawnBtn" text="立即重生" visible="false" managed="false"
                        style="-fx-background-color: #4ecca3; -fx-text-fill: #0f3460; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 4 16;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
